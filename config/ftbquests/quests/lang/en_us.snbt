	quest.3ADD69413C0798FE.quest_desc: ["i heard theres these weird eyeball thingies scattered all over the world. and if i catch 'em all and put them in the weird blinky jars i win a free trip to somewhere blobbins never been before! its gonna be the best souvenir collection ever!!!"]
	quest.3ADD69413C0798FE.title: "Blobbo's big Adventure"
