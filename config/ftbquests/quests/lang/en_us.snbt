	quest.0937A1CC74795CF4.quest_desc: [
		"&7Spear hook"
		"- attaches to any block except blocks with high hardness (metal blocks, obsidian, etc.)"
		"- breaks glass"
		"- makes damage to entities on hit"
		"- long distance"
		"- medium rope elasticity"
		"- medium fire resistance"
		""
		"&9Web hook"
		"- sticks to any surface except sandy blocks"
		"- safe for other players (makes no damage)"
		"- long distance"
		"- high rope elasticity"
		"- low fire resistance"
		""
		"&4Pudge hook"
		"- attaches to tree leaves, poles, iron bars and fences"
		"- rips out torches, bells and lanterns"
		"- pulls entities and players"
		"- dismounts riding entities"
		"- auto-pulling"
		"- medium distance"
		"- high hook strength"
		"- high fire resistance"
	]
	quest.0937A1CC74795CF4.title: "Choose Starting Hook"
	quest.093FB7B7FEC6B886.quest_desc: ["{cabin.quest.093FB7B7FEC6B886.description1}"]
	quest.093FB7B7FEC6B886.quest_subtitle: "{cabin.quest.093FB7B7FEC6B886.subtitle}"
	quest.093FB7B7FEC6B886.title: "{cabin.quest.093FB7B7FEC6B886.title}"
	quest.0940460C24391D32.quest_desc: [
		"While Cactoids have a reputation for spewing all sorts of things, gunpowder is the most famous. Endosymbiotic glands in every Cactoid's digestive tract can rapidly digest rotten flesh into gunpowder, which is immediately vomited back up."
		""
		"It's thought the Cactoids' enigmatic progenitors engineered them with this ability, but no one's quite sure what its original purpose was. Nowadays, it's mainly used as a defense mechanism in times of great need."
		""
		"Well, you have a need. A need for ammunition. Now eat the flesh."
	]
	quest.0940460C24391D32.title: "Regurgitated Slop"
	quest.097BF458D48E4B46.quest_desc: ["An ancient legend passed down among rat-kind says the moon is made of cheese. If you make it to the moon someday, all that cheese could be yours..."]
	quest.097BF458D48E4B46.title: "Moon Cheese"
