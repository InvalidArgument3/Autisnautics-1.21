	quest.68A8C2CB135ECA87.quest_desc: [
		"Atomic Mechanisms are so heavy-duty they need a base casted from Molten Steel. It's possible to fully automate Steel production, but not strictly necessary."
		""
		"If you don't have Steel production already, you can make it with a Blast Furnace from The Factory Must Grow or Immersive Engineering, or IE's Arc Furnace. Once you develop Lead Machines, you'll also have access to Nuclearcraft's Alloy Smelter."
	]
	quest.68A8C2CB135ECA87.quest_subtitle: "Contraption 20-1"
	quest.68A8C2CB135ECA87.title: "A Source of Steel"
