	quest.6E3CD6919EAA9EE4.quest_desc: [
		"For your garden-variety autist, building a glider would mean gathering leather and other parts from local fauna. But you &oare&r the local fauna."
		"With an axe and a cutting board, you can take a little bit off the top, and harvest the supplies you need..."
	]
	quest.6E3CD6919EAA9EE4.title: "Skin Off My Nose"
	quest.6EE9AA6D2A8FE0AD.quest_desc: [
		"Although some Uranium yet persists in this world in ancient waste dump sites, several other elements critical to nuclear technology, like Boron and Magnesium, have been truly depleted."
		""
		"However, analysis suggests these ores must have existed in the past."
		""
		"If the past is the only place to find them..."
	]
	quest.6EE9AA6D2A8FE0AD.title: "Epilogue: Rewriting History"
	quest.6F0E3626FD191407.title: "fwooosh"
